# Copie este arquivo para .env e preencha com suas chaves
# NUNCA commite o .env real

# Seu nome (como a Luna vai te chamar) — fica fora do código por privacidade
USUARIO_NOME=SeuNome

GEMINI_API_KEY=sua_chave_gemini_aqui

SPOTIPY_CLIENT_ID=seu_client_id_spotify
SPOTIPY_CLIENT_SECRET=seu_client_secret_spotify
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8080

EMAIL_USUARIO=seu_email@gmail.com
EMAIL_SENHA=senha_de_app_16_letras_sem_espacos

# Overwatch (battletag no formato Nome-1234)
OW_BATTLETAG=SeuNome-0000

# Steam (chave em steamcommunity.com/dev/apikey)
STEAM_API_KEY=sua_chave_steam
STEAM_ID=seu_steam_id_64bits

# Giphy (GIFs na interface web — giphy.com/dev)
GIPHY_API_KEY=sua_chave_giphy

# Hugging Face (geração de imagem — huggingface.co/settings/tokens)
# precisa da permissão "Make calls to Inference Providers"
HF_TOKEN=seu_token_hf_aqui

# Telegram (token do BotFather + seu chat id)
TELEGRAM_TOKEN=seu_token_telegram
TELEGRAM_CHAT_ID=seu_chat_id

# Obsidian (caminho do vault que a Luna lê; opcional)
OBSIDIAN_VAULT=C:\caminho\para\seu\vault

# Localização para a previsão do tempo (lat/long da sua cidade)
# Descubra a sua em: latlong.net — o padrão é o centro de Brasília
CLIMA_LAT=-15.7942
CLIMA_LON=-47.8822
